{
  "manifest_version": 3,
  "name": "Ya Snooze, Ya Win",
  "short_name": "snoozewin",
  "version": "13.0.11",
  "description": "Snooze a tab or group of tabs and they will reopen automatically later.",
  "icons": {
    "128": "images/extension_icon_128.png"
  },
  "author": "Conveyor",
  "permissions": [
    "offscreen",
    "tabs",
    "activeTab",
    "alarms",
    "storage",
    "notifications",
    "idle",
    "contextMenus"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*",
        "fonts/*",
        "sounds/*",
        "offscreen.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Snooze This Tab",
    "default_popup": "index.html#popup",
    "default_icon": {
      "32": "images/browser_action_32.png"
    }
  },
  "options_page": "index.html#options/settings",
  "background": {
    "service_worker": "src/core/backgroundMain.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Snooze active tab"
    },
    "repeat_last_snooze": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "Repeat last snooze action"
    },
    "open_snoozed_list": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "Open snoozed tabs list"
    }
  }
}
